{
  "name": "@effect-app-boilerplate/e2e",
  "version": "1.0.0",
  "license": "NONE",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:watch": "playwright-watch test",
    "build": "tsc --build",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 ESLINT_TS=1 eslint .",
    "lint:watch": "ESLINT_TS=1 esw -w --changed --clear --ext ts,tsx .",
    "lint-fix": "pnpm lint --fix",
    "up": "pnpm run update && pnpm exec-update",
    "update": "pnpm ncu -u",
    "exec-update": "pnpm i",
    "clean": "rm -rf test-out",
    "ncu": "ncu",
    "watch": "pnpm build --watch"
  },
  "devDependencies": {
    "@playwright/test": "~1.59.1",
    "@types/node": "~25.6.0",
    "date-fns": "^4.1.0",
    "npm-check-updates": "^21.0.3",
    "playwright-core": "^1.59.1",
    "playwright-watch": "^1.3.23",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "@effect-app-boilerplate/api": "workspace:*",
    "@effect/platform-node": "4.0.0-beta.59",
    "effect-app": "4.0.0-beta.178",
    "effect": "4.0.0-beta.59",
    "cross-fetch": "^4.1.0",
    "eslint": "^10.2.1",
    "dprint": "^0.54.0"
  }
}