    "@opentelemetry/propagator-b3": "^2.6.0",
    "@opentelemetry/tracing": "^0.24.0",
    "@opentelemetry/web": "^0.24.0",
    "@sentry/browser": "10.42.0",
    "@sentry/opentelemetry": "10.42.0",
