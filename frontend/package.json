{
  "name": "@effect-app-boilerplate/frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "check": "([ ! -d './.nuxt' ] && nuxt prepare || echo 'no prepare') && vue-tsc --noEmit",
    "watch": "pnpm check -w",
    "dev": "PORT=4000 nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "ncu": "ncu",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint .",
    "lint-fix": "pnpm lint --fix",
    "testsuite": "pnpm lint",
    "clean": "rm -rf ./.nuxt ./node_modules/.cache"
  },
  "dependencies": {
    "@effect-app/vue": "4.0.0-beta.34",
